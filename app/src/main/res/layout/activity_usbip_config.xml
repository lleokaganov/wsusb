<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="28dp">

        <!-- Title is already shown in the system action bar (android:label="wsusb"
             on the activity), so we only render the tagline + Settings button
             here — no second "wsusb" header. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_tagline"
                android:textColor="@color/tagline"
                android:textSize="14sp" />

            <Button
                android:id="@+id/settingsButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="@string/settings_button" />
        </LinearLayout>

        <!-- =============================================================
             PROMINENT relay-server connection state (red / amber / green).
             A 14dp tinted dot + a one-line label so the user can see at a
             glance whether the WS link to the relay is up.
             ============================================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/connDot"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/dot_status"
                android:backgroundTint="@color/status_idle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginLeft="8dp"
                android:text="@string/conn_status_label"
                android:textColor="@color/helper_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/connStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginLeft="6dp"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- =============================================================
             SECTION — DEVICE (live USB status + combined sharing status)
             Sharing is raised automatically whenever a device is attached
             (accept mode needs no peer); the button is a manual override only.
             ============================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:letterSpacing="0.08"
            android:text="@string/section_device"
            android:textColor="@color/section_heading"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:background="@color/separator" />

        <!-- Live USB device line(s): one row per attached device, updated by
             the USB receiver. All listed devices are available to the remote
             side (it picks one via "usbip attach -b <busid>"). -->
        <TextView
            android:id="@+id/usbDeviceInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/usb_none"
            android:textSize="14sp"
            android:textStyle="bold"
            android:typeface="monospace" />

        <!-- Second separator: visually closes the "list of devices" box so the
             traffic / help text below is not mistaken for another device. -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="@color/separator" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/device_section_hint"
            android:textColor="@color/helper_text"
            android:textSize="13sp" />

        <!-- TX/RX traffic dots: they blink when usbws emits "STAT tx=1" /
             "rx=1" so the user can tell at a glance the tunnel has live data
             flowing through it — independent of the relay-connected state. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/traffic_label"
                android:textColor="@color/helper_text"
                android:textSize="12sp" />

            <View
                android:id="@+id/dotTx"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="8dp"
                android:alpha="0.15"
                android:background="@drawable/dot_tx" />

            <View
                android:id="@+id/dotRx"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="6dp"
                android:alpha="0.15"
                android:background="@drawable/dot_rx" />
        </LinearLayout>

        <!-- Manual override: only enabled/visible while something is being shared. -->
        <Button
            android:id="@+id/stopSharingButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/stop_sharing" />

        <!-- =============================================================
             SECTION — YOUR INVITE (copy, give to peer)
             ============================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:letterSpacing="0.08"
            android:text="@string/section_your_invite"
            android:textColor="@color/section_heading"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:background="@color/separator" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/your_invite_hint"
            android:textColor="@color/helper_text"
            android:textSize="13sp" />

        <!-- Read-only invite field: faint fill + padding make it look non-editable. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/myInvite"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@color/readonly_field_bg"
                android:padding="10dp"
                android:text="(generating...)"
                android:textIsSelectable="true"
                android:textSize="12sp"
                android:typeface="monospace" />

            <Button
                android:id="@+id/copyInviteButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginLeft="10dp"
                android:minWidth="88dp"
                android:text="@string/copy" />
        </LinearLayout>

        <!-- =============================================================
             SECTION — OWNERS (authorized remotes that may connect)
             Filled from the usbws "authorized" table. The first remote that
             connects with our invite is trusted-on-first-use and listed here;
             afterwards only listed owners are accepted.
             ============================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:letterSpacing="0.08"
            android:text="@string/section_owners"
            android:textColor="@color/section_heading"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:background="@color/separator" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/owners_hint"
            android:textColor="@color/helper_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/ownersList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/owners_none"
            android:textSize="13sp"
            android:typeface="monospace" />

        <!-- Visible only when the authorized table is non-empty (see refreshOwners). -->
        <Button
            android:id="@+id/forgetOwnersButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/forget_owners"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
