<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="28dp">

        <!-- ===== Title / tagline ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_title"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/app_tagline"
            android:textColor="@color/tagline"
            android:textSize="14sp" />

        <!-- =============================================================
             SECTION — DEVICE (live USB status + combined sharing status)
             Sharing is raised automatically whenever a device is attached
             (accept mode needs no peer); the button is a manual override only.
             ============================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:letterSpacing="0.08"
            android:text="@string/section_device"
            android:textColor="@color/section_heading"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:background="@color/separator" />

        <!-- Live USB device line (none / technical info, updated by the receiver). -->
        <TextView
            android:id="@+id/usbDeviceInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/usb_none"
            android:textSize="14sp"
            android:textStyle="bold"
            android:typeface="monospace" />

        <!-- Combined sharing status: e.g. "Sharing: CH340 1a86:7523 → relay connected". -->
        <TextView
            android:id="@+id/combinedStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/device_section_hint"
            android:textColor="@color/helper_text"
            android:textSize="13sp" />

        <!-- Manual override: only enabled/visible while something is being shared. -->
        <Button
            android:id="@+id/stopSharingButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/stop_sharing" />

        <!-- =============================================================
             SECTION — YOUR INVITE (copy, give to peer)
             ============================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:letterSpacing="0.08"
            android:text="@string/section_your_invite"
            android:textColor="@color/section_heading"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:background="@color/separator" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/your_invite_hint"
            android:textColor="@color/helper_text"
            android:textSize="13sp" />

        <!-- Read-only invite field: faint fill + padding make it look non-editable. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/myInvite"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@color/readonly_field_bg"
                android:padding="10dp"
                android:text="(generating...)"
                android:textIsSelectable="true"
                android:textSize="12sp"
                android:typeface="monospace" />

            <Button
                android:id="@+id/copyInviteButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginLeft="10dp"
                android:minWidth="88dp"
                android:text="@string/copy" />
        </LinearLayout>

        <!-- =============================================================
             SECTION — OWNERS (authorized remotes that may connect)
             Filled from the usbws "authorized" table. The first remote that
             connects with our invite is trusted-on-first-use and listed here;
             afterwards only listed owners are accepted.
             ============================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:letterSpacing="0.08"
            android:text="@string/section_owners"
            android:textColor="@color/section_heading"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:background="@color/separator" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/owners_hint"
            android:textColor="@color/helper_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/ownersList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/owners_none"
            android:textSize="13sp"
            android:typeface="monospace" />

        <!-- Visible only when the authorized table is non-empty (see refreshOwners). -->
        <Button
            android:id="@+id/forgetOwnersButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/forget_owners"
            android:visibility="gone" />

        <!-- =============================================================
             SECTION — APP (version + self-update)
             ============================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:letterSpacing="0.08"
            android:text="@string/section_app"
            android:textColor="@color/section_heading"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:background="@color/separator" />

        <TextView
            android:id="@+id/appVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/helper_text"
            android:textSize="13sp" />

        <Button
            android:id="@+id/updateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/check_for_updates" />

    </LinearLayout>

</ScrollView>
