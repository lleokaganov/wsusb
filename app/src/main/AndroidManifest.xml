<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="26"
    android:versionName="0.8.7" >

    <uses-feature android:name="android.hardware.usb.host" android:required="true" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Required for the in-app self-update to launch the package installer. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Lets us prompt the user to whitelist us from battery optimizations so
         the relay stays connected with the screen off / app in background. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name="me.lleo.wsusb.WsusbApp"
        android:allowBackup="true"
        android:extractNativeLibs="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">

        <service
            android:label="@string/service_name"
            android:name="me.lleo.wsusb.service.UsbIpService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE" android:value="Allows continued access to USB devices via USB/IP while in the background" />
        </service>

        <activity
            android:name="me.lleo.wsusb.config.UsbIpConfig"
            android:exported="true"
            android:resizeableActivity="true"
            android:label="@string/app_name" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Device-filter capture: when a USB device whose vendor matches
                 res/xml/device_filter.xml is attached, Android offers to always
                 open wsusb for it, then auto-launches this activity on plug-in. -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>

        <activity
            android:name="me.lleo.wsusb.config.SettingsActivity"
            android:exported="false"
            android:parentActivityName="me.lleo.wsusb.config.UsbIpConfig"
            android:label="@string/settings_title" />

        <!-- Exposes the downloaded update APK to the system installer via content:// Uri. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
